{
  "name": "signagecms/signagecms",
  "description": "Digital Signage Management System for Restaurants",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "cboden/ratchet": "^0.4.4",
    "react/event-loop": "^1.4",
    "phpmailer/phpmailer": "^6.8",
    "intervention/image": "^2.7",
    "league/flysystem": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "start": "php -S 0.0.0.0:8000 -t public public/index.php",
    "ws": "php websocket/server.php",
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
