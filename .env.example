# Application
APP_NAME="SignageCMS"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost
APP_KEY=base64:generate-a-32-char-secret-key-here
APP_TIMEZONE=Asia/Tehran

# Database
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=signage_cms
DB_USERNAME=signage_user
DB_PASSWORD=StrongPassword123!
DB_CHARSET=utf8mb4

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRY=86400
JWT_REFRESH_EXPIRY=604800

# WebSocket
WS_HOST=0.0.0.0
WS_PORT=8080
WS_ALLOWED_ORIGINS=*

# Redis (for real-time & caching)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# Storage
STORAGE_DRIVER=local
MAX_UPLOAD_SIZE=524288000
ALLOWED_MEDIA_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,video/webm

# Mail (for notifications)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM=noreply@signagecms.com

# Weather API (for weather widget)
WEATHER_API_KEY=your-openweathermap-api-key
WEATHER_DEFAULT_CITY=Tehran

# Security
CSRF_TOKEN_EXPIRY=3600
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
SESSION_LIFETIME=7200
BCRYPT_ROUNDS=12

# Multi-tenant
MULTI_TENANT=true
DEFAULT_TENANT=main

# Admin
ADMIN_EMAIL=admin@signagecms.com
ADMIN_PASSWORD=Admin@123456
